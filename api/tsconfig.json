{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "outDir": "../dist/api",
    "rootDir": ".",
    "paths": {
      "@workspace/db": ["../lib/db/src/index.ts"],
      "@workspace/db/schema": ["../lib/db/src/schema/index.ts"],
      "@workspace/api-zod": ["../lib/api-zod/src/index.ts"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
