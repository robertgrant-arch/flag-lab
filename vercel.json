{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/flaglab run build",
  "outputDirectory": "artifacts/flaglab/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
